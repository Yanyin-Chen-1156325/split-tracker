generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["split_tracker"]
}

model Group {
  id        String        @id @default(cuid())
  name      String
  createdAt DateTime      @default(now())
  expenses  Expense[]
  members   GroupMember[]

  @@schema("split_tracker")
}

model GroupMember {
  id      String @id @default(cuid())
  name    String
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@schema("split_tracker")
}

model Expense {
  id          String         @id @default(cuid())
  description String
  amount      Float
  paidBy      String
  date        DateTime       @default(now())
  closed      Boolean        @default(false)
  createdAt   DateTime       @default(now())
  groupId     String
  group       Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  splits      ExpenseSplit[]

  @@schema("split_tracker")
}

model ExpenseSplit {
  id         String  @id @default(cuid())
  memberName String
  expenseId  String
  expense    Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@schema("split_tracker")
}
